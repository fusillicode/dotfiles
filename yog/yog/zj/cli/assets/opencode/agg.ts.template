import type { Plugin } from "@opencode-ai/plugin";
import type { Event } from "@opencode-ai/sdk";

type AggEventKind = "start" | "busy" | "idle" | "exit";

const AGENT = "opencode";
const PIPE = "{{AGENTS_PIPE}}";

function kindFromEvent(event: Event): AggEventKind | undefined {
  switch (event.type) {
    case "session.created":
      return "start";
    case "session.deleted":
      return "exit";
    case "session.error":
    case "session.idle":
      return "idle";
    case "session.status":
      switch (event.properties.status.type) {
        case "busy":
        case "retry":
          return "busy";
        case "idle":
          return "idle";
      }
  }
}

export const AggHooksPlugin: Plugin = async ({ $ }) => {
  const paneID = process.env.ZELLIJ_PANE_ID;
  if (!paneID) {
    return {};
  }

  try {
    await $`which zellij`.quiet();
  } catch {
    return {};
  }

  let lastEvent: AggEventKind | undefined;

  const send = async (kind: AggEventKind) => {
    if (lastEvent === kind) {
      return;
    }

    try {
      await $`zellij pipe --name ${PIPE} --args ${`pane_id=${paneID},agent=${AGENT}`} -- ${kind}`.quiet();
      lastEvent = kind;
    } catch {
    }
  };

  return {
    event: async ({ event }) => {
      const kind = kindFromEvent(event);
      if (!kind) {
        return;
      }
      await send(kind);
    },
    "tool.execute.before": async () => {
      await send("busy");
    },
  };
};

export default AggHooksPlugin;
